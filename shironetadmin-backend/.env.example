# —— Cloudflare R2（S3 兼容 API），两套连接彼此独立 ——

# --- 旧业务：管理台「数据下载」（/dashboard/data-download）列对象与预签名下载 ---
R2_OPTSTOR_BUCKET=
R2_OPTSTOR_ENDPOINT=
R2_OPTSTOR_ACCESS_KEY_ID=
R2_OPTSTOR_SECRET_ACCESS_KEY=

# --- 新业务：ZIP 解析等写入的静态资源 ---
R2_STATICSTOR_BUCKET=
R2_STATICSTOR_ENDPOINT=
R2_STATICSTOR_ACCESS_KEY_ID=
R2_STATICSTOR_SECRET_ACCESS_KEY=

# 对象键前缀（与 CDN / 自定义域名路径对齐；勿带首尾斜杠以外的多余字符）
# 主游戏资源树：avatar、map-icon、jacket、trophy、system-voice-icon 等在其下二级目录
R2_KEY_PREFIX_GAME_TREE=chuni
# 姓名板：桶内实测多为桶根扁平前缀 name-plate/
R2_KEY_PREFIX_NAMEPLATE=name-plate

# ZIP 内的 DDS（DXT）是否在服务端转为 WebP 再上传（默认启用）；设为 false 则保留 DDS 原文件扩展名与 Content-Type
R2_DDS_CONVERT_WEBP=true

# 请在控制台妥善保管密钥；若密钥曾泄露，请立即轮换。
#
# 已废弃：R2_BUCKET、R2_ENDPOINT、R2_ACCESS_KEY_ID、R2_SECRET_ACCESS_KEY（统一改由上方两套 R2_*STOR_* 配置）
